{
  "name": "wiki-steami",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "lint:md": "markdownlint \"docs/**/*.md\"",
    "lint:md:fix": "markdownlint --fix \"docs/**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint --fix .",
    "lint:links": "docker run --rm -v $PWD:/input lycheeverse/lychee --config /input/.lychee.toml --root-dir /input/static '/input/docs/**/*.md' '/input/README.md'",
    "prepare": "husky"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "git-precommit-checks": "3.1.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.8.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "lint-staged": {
    "*.md": "markdownlint",
    "*.{js,jsx}": [
      "eslint",
      "prettier --check"
    ],
    "*.{json,css,yml,yaml}": "prettier --check"
  },
  "engines": {
    "node": ">=20.17.0"
  }
}
