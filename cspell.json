{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "fr,en",
  "import": ["@cspell/dict-fr-fr/cspell-ext.json"],
  "dictionaries": ["fr-fr", "steami-terms"],
  "dictionaryDefinitions": [
    {
      "name": "steami-terms",
      "path": ".cspell/steami.txt",
      "addWords": true
    }
  ],
  "files": ["docs/**/*.md", "README.md", "CONTRIBUTING.md"],
  "ignorePaths": [
    "node_modules",
    "build",
    ".external",
    ".docusaurus",
    "package-lock.json",
    "static"
  ],
  "ignoreRegExpList": [
    "/(```[\\s\\S]*?```)/g",
    "/`[^`]+`/g",
    "/https?:\\/\\/\\S+/g",
    "/\\[.*?\\]\\(.*?\\)/g",
    "/!\\[.*?\\]\\(.*?\\)/g",
    "/import\\s+.*?from\\s+.*?;/g",
    "/<OctopartButton[^>]*\\/>/g",
    "/\\b[A-Z][A-Z0-9_]{2,}\\b/g"
  ],
  "ignoreWords": [],
  "flagWords": [
    "developpement",
    "memoire",
    "peripherique",
    "microcontroleur",
    "controleur",
    "systeme",
    "ecran",
    "electronique",
    "electrique",
    "accelerometre",
    "magnetometre",
    "caracteristiques",
    "schemas",
    "schema"
  ]
}
